# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Secrets / local config (keep NVD API keys out of git)
.env
*.key

# Transient Gemma reviewer run logs — local stdout captures, regenerable
gemma_*.log

# macOS / Windows / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/

# Note: research data (*.xlsx, *.csv, *.docx, *.pdf) is intentionally NOT ignored —
# it is the project's dataset and is tracked on purpose.

# Exception: the raw NVD snapshot is large, reproducible bulk data (not curated
# project output) — keep it out of git. SNAPSHOT.md (provenance) IS tracked.
data/nvd-snapshot/*.csv
data/nvd-snapshot/*.json
data/nvd-snapshot/*.json.gz

# Per-category prep marker touched by run_gemma_column.sh — local, per-machine
# bookkeeping only. Must NOT be tracked: if checked out elsewhere it would make
# the script skip the one-time backup/blank of the Gemini column.
data/difference/*/.gemma_prepped
